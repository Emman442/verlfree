rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VERIFREE SECURITY RULES - PROTOTYPING VERSION
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict ownership and role-based access model to secure 
     * a decentralized job board. It prioritizes "Authorization Independence" by 
     * ensuring documents contain necessary UID fields (clientId, freelancerId) 
     * to perform security checks without excessive cross-document lookups.
     * 
     * Data Structure:
     * - /userProfiles/{userId}: Private-by-default profiles where the document ID matches the Auth UID.
     * - /jobs/{jobId}: Top-level job listings. Publicly readable, but only manageable by the posting client 
     *   or the assigned freelancer for specific actions (deliverable submission).
     * - /jobs/{jobId}/applications/{applicationId}: Sub-collection for job applications. Secured by 
     *   verifying the applicant's UID and the denormalized job owner's UID (jobClientId).
     * 
     * Key Security Decisions:
     * 1. Denormalization for Performance: Jobs and Applications store UIDs of involved parties 
     *    directly to allow O(1) authorization checks.
     * 2. Status-Based Access: Logic assumes UI state management, while rules enforce that only 
     *    authorized UIDs can trigger status transitions (e.g., a client selecting a freelancer).
     * 3. Public Readability: Job listings are public to allow a "Job Board" experience, 
     *    while specific user data remains protected.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the provided UID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the authenticated user is the owner of the existing document. */
    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    /** Performs a lookup to see if the authenticated user is the client of a specific job. */
    function isJobClient(jobId) {
      return isSignedIn() && get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Users own their documents (path-based).
     * @path /userProfiles/{userId}
     * @allow (get) Any signed-in user to view profile details.
     * @allow (create, update) Only the user whose UID matches the document ID.
     * @deny (write) If the UID does not match the path.
     * @principle Path-based ownership and verified identity.
     */
    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for job listings. Clients own jobs; assigned freelancers can submit deliverables.
     * @path /jobs/{jobId}
     * @allow (get, list) All users to browse the job board.
     * @allow (create) Signed-in users, enforcing their UID as the clientId.
     * @allow (update) The Job Client (full edit) or the Assigned Freelancer (limited to deliverable submission).
     * @deny (write) Any non-owner or unassigned user.
     * @principle Ownership-based writes with shared access for active collaborators.
     */
    match /jobs/{jobId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isExistingOwner("clientId") || isExistingOwner("assignedFreelancerId");
      allow delete: if isExistingOwner("clientId");
    }

    /**
     * @description Rules for job applications. Accessible by the applicant and the job's client.
     * @path /jobs/{jobId}/applications/{applicationId}
     * @allow (get) The applicant or the job owner.
     * @allow (create) Any freelancer applying (enforces freelancerId matches auth UID).
     * @allow (update) The applicant (cancel/edit) or the Job Client (reject/select/shortlist).
     * @allow (list) The Job Client to see all applicants for their job.
     * @deny (write) Users not explicitly involved in the job or application.
     * @principle Denormalized authorization using 'jobClientId' for fast lookup-free checks.
     */
    match /jobs/{jobId}/applications/{applicationId} {
      
      // Helper to check if user is either the applicant or the job's client
      function isInvolvedInApplication() {
        return isExistingOwner("freelancerId") || isExistingOwner("jobClientId");
      }

      allow get: if isSignedIn() && isInvolvedInApplication();
      
      // Clients list applications for their jobs via path-based lookup
      allow list: if isSignedIn() && isJobClient(jobId);

      allow create: if isSignedIn() 
        && request.resource.data.freelancerId == request.auth.uid
        && request.resource.data.jobId == jobId;

      allow update: if isSignedIn() 
        && (isExistingOwner("freelancerId") || isExistingOwner("jobClientId"))
        && request.resource.data.freelancerId == resource.data.freelancerId;

      allow delete: if isExistingOwner("freelancerId");
    }

    /**
     * @description Collection Group rules for Applications to support Freelancer "Applied Jobs" dashboard.
     * @principle QAP (Query-Agnostic Permissions) for cross-collection tracking.
     */
    match /{path=**}/applications/{applicationId} {
      allow list: if isSignedIn(); // Queries must be filtered by freelancerId == auth.uid in client code
    }
  }
}